# Web Server
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars

# MCP Server
MCP_PORT=3001
MCP_SECRET=change-this-to-another-strong-secret
MCP_OUTPUT_LIMIT=12000

# Database
DB_PATH=./data/app.db

# Workspace root (where user project directories are stored)
WORKSPACE_ROOT=/workspace
RELAY_STATE_ROOT=/workspace/.relay-mcp
RELAY_UPLOAD_TTL_MS=900000
RELAY_UPLOAD_MAX_BYTES=268435456
RELAY_DOWNLOAD_TTL_MS=900000

# SSH
SSH_KEYS_DIR=/workspace/.ssh-keys
